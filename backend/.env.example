
# Application Settings
FRONTEND_ORIGIN=http://localhost:8000
APP_SECRET_KEY=change-me-in-production

# Database Settings
DATABASE_URL=postgresql+asyncpg://wordpress_agent:changeme@localhost:5432/wordpress_agent_db
POSTGRES_USER=wordpress_agent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wordpress_agent_db
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# WordPress Connector Encryption (comma-separated Fernet keys; first key is used for new encryptions)
WP_CONNECTOR_FERNET_KEYS=

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# LLM Provider API Keys
GROQ_API_KEY=gsk_your_api_key_here
ZAI_API_KEY=your_zai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Agent Settings
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
GLM5_MODEL=glm-5
GEMINI_MODEL=gemini-2.5-flash
RECURSION_LIMIT=25
RETRY_ATTEMPTS=3
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=wordpress-agent
CHECKPOINT_DB_PATH=agent_state.db
