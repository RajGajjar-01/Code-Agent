# ============================================
#  Groq AI Configuration
# ============================================
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
#  WordPress Configuration
# ============================================
# Generate an Application Password in WP Admin > Users > Profile > Application Passwords
WP_BASE_URL=https://your-wordpress-site.com
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================
#  Google OAuth 2.0
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ============================================
#  Database
# ============================================
DATABASE_URL=postgresql+asyncpg://wordpress_agent:changeme@localhost:5432/wordpress_agent_db

# ============================================
#  PostgreSQL (Docker Compose)
# ============================================
POSTGRES_USER=wordpress_agent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wordpress_agent_db

# ============================================
#  pgAdmin
# ============================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ============================================
#  App
# ============================================
APP_SECRET_KEY=change-me-in-production
FRONTEND_ORIGIN=http://localhost:8000
